@page "/"
@using System.ComponentModel
@inject IChatClient ChatClient
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Chat</PageTitle>

<ChatHeader OnNewChat="@ResetConversationAsync" />

<ChatMessageList Messages="@messages" InProgressMessage="@currentResponseMessage">
    <NoMessagesContent>
        <div>
            I'm your friendly interview coach. To get started, upload your resume and job description.
        </div>
    </NoMessagesContent>
</ChatMessageList>

<div class="chat-container">
    <ChatInput OnSend="@AddUserMessageAsync" @ref="@chatInput" />
</div>

@code {
    private const string SystemPrompt = @"
        You are an professional interview coach.
        Your goal is to help users prepare for job interviews by providing insightful feedback, asking relevant questions, and offering constructive criticism.
        Always maintain a supportive and encouraging tone.
        ";

    private const string SessionStorageKey = "interview-coach.session-id";

    private int statefulMessageCount;
    private readonly ChatOptions chatOptions = new();
    private readonly List<ChatMessage> messages = new();
    private CancellationTokenSource? currentResponseCancellation;
    private ChatMessage? currentResponseMessage;
    private ChatInput? chatInput;
    private Guid interviewSessionId;
    private bool sessionInitialized;

    protected override void OnInitialized()
    {
        statefulMessageCount = 0;
        chatOptions.Tools = [];
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await EnsureSessionInitializedAsync();
        }
    }

    private async Task EnsureSessionInitializedAsync()
    {
        if (sessionInitialized)
        {
            return;
        }

        var storedSessionId = await JS.InvokeAsync<string>("sessionStorage.getItem", SessionStorageKey);
        if (Guid.TryParse(storedSessionId, out var parsedSessionId))
        {
            interviewSessionId = parsedSessionId;
        }
        else
        {
            interviewSessionId = Guid.NewGuid();
            await JS.InvokeVoidAsync("sessionStorage.setItem", SessionStorageKey, interviewSessionId.ToString());
        }

        InitializeConversation(interviewSessionId);
        sessionInitialized = true;
        StateHasChanged();
    }

    private void InitializeConversation(Guid sessionId)
    {
        messages.Clear();
        messages.Add(new(ChatRole.System, SystemPrompt));
        messages.Add(new(ChatRole.System, $"<sessionId>{sessionId}</sessionId>"));
        messages.Add(new(ChatRole.Assistant, $"I'm your friendly interview coach. To get started, upload your resume and job description. Here's your interview session ID: {sessionId}"));
        statefulMessageCount = 0;
    }

    private async Task AddUserMessageAsync(ChatMessage userMessage)
    {
        CancelAnyCurrentResponse();

        messages.Add(userMessage);
        await chatInput!.FocusAsync();

        var responseText = new TextContent("");
        currentResponseMessage = new ChatMessage(ChatRole.Assistant, [responseText]);
        currentResponseCancellation = new();

        await GetStreamingResponseAsync(responseText, currentResponseMessage, currentResponseCancellation.Token);

        messages.Add(currentResponseMessage!);
        statefulMessageCount = chatOptions.ConversationId is not null ? messages.Count : 0;
        currentResponseMessage = null;
    }

    private async Task GetStreamingResponseAsync(TextContent responseText, ChatMessage responseMessage, CancellationToken cancellationToken)
    {
        var currentResponseText = responseText;
        var currentResponseMessage = responseMessage;
        var currentAuthorName = responseMessage.AuthorName;
        var deferAssistantTextUntilToolResponse = false;
        var toolResponseSeen = false;
        await foreach (var update in ChatClient.GetStreamingResponseAsync(messages.Skip(statefulMessageCount), chatOptions, cancellationToken))
        {
            await Task.Delay(50);

            messages.AddMessages(update, filter: c => c is not TextContent);

            if (update.Role == ChatRole.Assistant)
            {
                var updateAuthorName = string.IsNullOrWhiteSpace(update.AuthorName) ? null : update.AuthorName;

                if (updateAuthorName is not null && currentAuthorName is not null &&
                    string.Equals(updateAuthorName, currentAuthorName, StringComparison.Ordinal) == false)
                {
                    messages.Add(currentResponseMessage);

                    currentResponseText = new TextContent("");
                    currentResponseMessage = new ChatMessage(ChatRole.Assistant, [currentResponseText])
                    {
                        AuthorName = updateAuthorName
                    };
                    currentAuthorName = updateAuthorName;
                    this.currentResponseMessage = currentResponseMessage;
                    ChatMessageItem.NotifyChanged(currentResponseMessage);
                }
                else if (currentAuthorName is null && updateAuthorName is not null)
                {
                    currentResponseMessage.AuthorName = updateAuthorName;
                    currentAuthorName = updateAuthorName;
                    ChatMessageItem.NotifyChanged(currentResponseMessage);
                }
            }

            if (deferAssistantTextUntilToolResponse == false && update.Role == ChatRole.Assistant && ContainsFunctionCall(update))
            {
                deferAssistantTextUntilToolResponse = true;
            }

            if (update.Role == ChatRole.Tool || ContainsFunctionResult(update))
            {
                toolResponseSeen = true;
            }

            if ((deferAssistantTextUntilToolResponse == false || toolResponseSeen == true) && update.Role == ChatRole.Assistant)
            {
                AppendAssistantText(update, currentResponseText, currentResponseMessage);
            }

            chatOptions.ConversationId = update.ConversationId;
            StateHasChanged();
        }

        static bool ContainsFunctionCall(ChatResponseUpdate update)
        {
            if (update.Contents.Any() == false)
            {
                return false;
            }

            return update.Contents.Any(c => c is FunctionCallContent);
        }

        static bool ContainsFunctionResult(ChatResponseUpdate update)
        {
            if (update.Contents.Any() == false)
            {
                return false;
            }

            return update.Contents.Any(c => c is FunctionResultContent);
        }

        static void AppendAssistantText(ChatResponseUpdate update, TextContent targetText, ChatMessage targetMessage)
        {
            if (update.Contents.Any() == false)
            {
                return;
            }

            foreach (var content in update.Contents)
            {
                if (content is TextContent { Text: { Length: > 0 } text })
                {
                    targetText.Text += text;
                }
            }

            ChatMessageItem.NotifyChanged(targetMessage);
        }
    }

    private void CancelAnyCurrentResponse()
    {
        if (currentResponseMessage is not null)
        {
            messages.Add(currentResponseMessage);
        }

        currentResponseCancellation?.Cancel();
        currentResponseMessage = null;
    }

    private async Task ResetConversationAsync()
    {
        CancelAnyCurrentResponse();
        interviewSessionId = Guid.NewGuid();
        await JS.InvokeVoidAsync("sessionStorage.setItem", SessionStorageKey, interviewSessionId.ToString());
        InitializeConversation(interviewSessionId);
        chatOptions.ConversationId = null;
        await chatInput!.FocusAsync();
    }

    public void Dispose()
        => currentResponseCancellation?.Cancel();
}
